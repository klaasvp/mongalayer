{
    "compilerOptions": {
        "target": "esnext",
        "module": "preserve",        
        "strict": true,                               
        "esModuleInterop": true,                     
        "skipLibCheck": true,                         
        "forceConsistentCasingInFileNames": true,     
        "isolatedModules": true,
        "composite": true
    },
    "include": [
        "./global.d.ts",
        "./global",
        "./data",
        "./src",
        "./jest.config.ts",
        "./jest.mongodb.config.ts"
    ],
    "exclude": [
        "./node_modules"
    ],
    "references": [
        { "path": "../server" }
    ]
}
  