{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",        
        "moduleResolution": "nodenext",                   
        "lib": ["ESNext"],                     
        "declaration": true,                          
        "declarationMap": true,                       
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",                      
        "strict": true,                               
        "esModuleInterop": true,                     
        "skipLibCheck": true,                         
        "forceConsistentCasingInFileNames": true,     
        "isolatedModules": true,
        "composite": true
    },
    "exclude": [
        "./dist",
        "./node_modules"
    ]
}
  