{
    "name": "@mongalayer/server",
    "type": "module",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./client": {
            "types": "./dist/client.d.ts"
        }
    },
    "scripts": {
        "build": "rm -rf ./dist/* && tsc --project tsconfig.build.json",
        "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" MONGOMS_DOWNLOAD_URL=\"https://fastdl.mongodb.org/linux/mongodb-linux-x86_64-ubuntu2204-8.0.11.tgz\" MONGOMS_VERSION=\"8.0.11\" npx vitest --run",
        "test-specific": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" MONGOMS_DOWNLOAD_URL=\"https://fastdl.mongodb.org/linux/mongodb-linux-x86_64-ubuntu2204-8.0.11.tgz\" MONGOMS_VERSION=\"8.0.11\" npx vitest --run $npm_config_pattern"
    },
    "dependencies": {
        "@mongalayer/core": "file:../core"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@faker-js/faker": "^10.1.0",
        "mongodb-memory-server": "^11.0.1"
    },
    "engines": {
        "node": ">=22"
    },
    "imports": {
        "#src/*": [
            "./src/*",
            "./src/*.ts"
        ],
        "#test/data/*": [
            "./__tests__/data/*",
            "./__tests__/data/*.ts"
        ],
        "#test/lib/*": [
            "./__tests__/lib/*",
            "./__tests__/lib/*.ts"
        ]
    }
}
