{
    "compilerOptions": {
        "target": "esnext",
        "module": "ESNext",        
        "moduleResolution": "bundler",                   
        "lib": ["DOM", "ESNext"],                     
        "declaration": true,                          
        "declarationMap": true,                       
        "sourceMap": true,
        "rootDir": ".",
        "outDir": "./dist",                           
        "strict": true,                               
        "noImplicitAny": true,                                        
        "esModuleInterop": true,                     
        "skipLibCheck": true,                         
        "forceConsistentCasingInFileNames": true,     
        "isolatedModules": true,
        "composite": true
    },
    "include": [
        "./src",
        "./__tests__"
    ],
    "exclude": [
        "./dist",
        "./node_modules"
    ]
}
  