{
    "name": "@mongalayer/core",
    "type": "module",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./utils/*": {
            "import": "./dist/utils/*.js",
            "types": "./dist/utils/*.d.ts"
        }
    },
    "scripts": {
        "build": "rm -rf ./dist/* && tsc --project tsconfig.build.json",
        "test": "npx vitest --run"
    },
    "devDependencies": {
        "vitest": "^3.2.4"
    },
    "imports": {
        "#src/*": [
            "./src/*",
            "./src/*.ts"
        ]
    }
}
